# ============================================================================
# PARAMETER GOLF — RUNPOD DEPLOYMENT CONFIG (CORRECTED)
# ============================================================================
# H100 SXM × 8 = EXACT competition hardware. High availability on RunPod.
# $2.69/hr × 8 = $21.52/hr → ~$3.59 for a 10-minute competition run.
# ============================================================================

COMPUTE_TYPE="GPU"
CLOUD_TYPE="Secure cloud"
REGION="Any Region"
GLOBAL_NETWORKING=false

# GPU: H100 SXM — the EXACT competition judging hardware
PREFER_GPU="H100 SXM"
GPU_COUNT=8

# Template: Official Parameter Golf environment
POD_TEMPLATE="runpod/parameter-golf:latest"
POD_NAME="parameter_golf_competition"

# Pricing
PRICING_PLAN="On-Demand"

# Pod options
ENCRYPT_VOLUME=false
SSH_TERMINAL_ACCESS=true
START_JUPYTER_NOTEBOOK=false

# Storage: Volume disk (local, fast I/O for training)
CONTAINER_DISK_GB=20
STORAGE_TYPE="Volume disk"
VOLUME_DISK_GB=50

# Budget guardrails
# 10-min run ≈ $3.59. Full sweep of 3 configs ≈ $11.
MAX_HOURLY_COST=25.00
MAX_RUNTIME_HOURS=2
